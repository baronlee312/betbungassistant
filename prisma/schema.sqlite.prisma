// This is your SQLite Prisma schema file,
// used to read data from the local dev.db file for migration.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-sqlite"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id          Int      @id @default(autoincrement())
  sofascoreId Int?     @unique
  name        String
  shortName   String?
  crestUrl    String?
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
}

model Match {
  id          Int      @id @default(autoincrement())
  sofascoreId Int?     @unique
  homeTeamId  Int
  awayTeamId  Int
  homeTeam    Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore   Int?
  awayScore   Int?
  date        DateTime
  time        String?
  status      String   // "FINISHED", "NOT_STARTED", etc.
  league      String
  season      String

  // Statistics
  homePossession    Int?
  awayPossession    Int?
  homeShots         Int?
  awayShots         Int?
  homeShotsOnTarget Int?
  awayShotsOnTarget Int?
  homeCorners       Int?
  awayCorners       Int?
  homeFouls         Int?
  awayFouls         Int?
  homeYellowCards   Int?
  awayYellowCards   Int?
  homeRedCards      Int?
  awayRedCards      Int?
  homeOffsides      Int?
  awayOffsides      Int?
  homeSaves         Int?
  awaySaves         Int?
  
  statisticsJson    String?
}

model FifaRanking {
  id             Int      @id @default(autoincrement())
  rank           Int
  teamName       String   @unique
  points         Float
  flagUrl        String?
  previousPoints Float?
  change         Float?
  lastUpdated    DateTime @default(now())
}
